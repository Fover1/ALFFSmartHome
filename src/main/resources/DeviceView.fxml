<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<ScrollPane xmlns:fx="http://javafx.com/fxml/1" fitToWidth="true" style="-fx-background-color: #332a2a;"
            xmlns="http://javafx.com/javafx/25" fx:controller="frontendController.DeviceController">
    <VBox spacing="15.0">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20"/>
        </padding>
        <HBox prefHeight="0.0" prefWidth="386.0">
            <Label fx:id="deviceName" prefHeight="26.0" prefWidth="214.0"
                   style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Label fx:id="deviceType" alignment="CENTER_RIGHT" contentDisplay="RIGHT" prefHeight="26.0"
                   prefWidth="214.0" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        </HBox>
        <HBox prefHeight="0.0" prefWidth="386.0">

        </HBox>
        <FlowPane fx:id="roomContainer" hgap="15.0" vgap="15.0">
            <Label fx:id="roomLabel" prefHeight="18.0" prefWidth="207.0" textFill="#999999"/>
            <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" prefHeight="18.0" prefWidth="154.0"
                   text="Status: Online" textFill="#999999"/>
        </FlowPane>
        <FlowPane fx:id="deviceContainer" hgap="15.0" vgap="15.0">
            <GridPane fx:id="deviceGrid" prefHeight="234.0" prefWidth="402.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="177.60001220703123" minWidth="10.0"
                                       prefWidth="177.60001220703123"/>
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="234.8000030517578" minWidth="9.599987792968761"
                                       prefWidth="24.999963378906273"/>
                    <ColumnConstraints hgrow="SOMETIMES" maxWidth="234.8000030517578" minWidth="10.0"
                                       prefWidth="107.40003662109376"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                </rowConstraints>
            </GridPane>
        </FlowPane>
    </VBox>
</ScrollPane>
